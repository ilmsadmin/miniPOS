<?xml version="1.0" encoding="utf-8"?>
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!--
        miniPOS Icon Foreground — Modern Dynamic Shopping Cart
        White cart icon with bold rounded strokes, dynamic swoosh angle.
        Centered on 108dp canvas within safe zone (24-84).
    -->

    <!-- Cart handle (angled bar extending from top-left) -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="5.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:pathData="M26,34 L34,40" />

    <!-- Cart body (swooping basket shape with dynamic tilt) -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M34,40 L38,38 L74,35
                          Q76,35 76,37
                          L72,56
                          Q71,59 68,59
                          L44,61
                          Q41,61 40,58
                          L36,44
                          Q35,41 38,38
                          Z" />

    <!-- Inner cut-out to create cart opening -->
    <path
        android:fillColor="@android:color/transparent"
        android:strokeColor="#FFFFFF"
        android:strokeWidth="3"
        android:strokeLineCap="round"
        android:pathData="M42,44 L70,41" />

    <!-- Left wheel -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M45,64 a4,4 0,1 1,8 0 a4,4 0,1 1,-8 0" />

    <!-- Right wheel -->
    <path
        android:fillColor="#FFFFFF"
        android:pathData="M62,63 a4,4 0,1 1,8 0 a4,4 0,1 1,-8 0" />

</vector>
