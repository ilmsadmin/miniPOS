<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base theme using Material3 with splash support -->
    <style name="Theme.MiniPOS" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">#1D4ED8</item>
        <item name="android:navigationBarColor">#FFFFFF</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme -->
    <style name="Theme.MiniPOS.Splash" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">#2563EB</item>
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher</item>
        <item name="postSplashScreenTheme">@style/Theme.MiniPOS</item>
    </style>
</resources>
